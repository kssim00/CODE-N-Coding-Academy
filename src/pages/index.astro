---
// 모든 html 파일을 가져옵니다.
const lessons = await Astro.glob('./lessons/*.html');

// 파일 경로에서 이름만 추출하는 안전한 함수
const getFileName = (path) => {
  const parts = path.split('/');
  const lastPart = parts[parts.length - 1];
  return lastPart.replace('.html', '');
};
---

<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>CODE:N ACADEMY - 파이썬 수업 자료실</title>
    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.8/dist/web/static/pretendard.css" />
    <style>
        body { font-family: 'Pretendard', sans-serif; background: #f5f6fa; margin: 0; padding: 40px; color: #2d3436; }
        header { text-align: center; margin-bottom: 50px; }
        .logo { width: 180px; height: auto; margin-bottom: 15px; } 
        h1 { font-size: 2.8rem; color: #6c5ce7; margin: 0; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 25px; max-width: 1100px; margin: 0 auto; }
        
        .card { 
            background: white; border-radius: 20px; padding: 30px; 
            box-shadow: 0 10px 20px rgba(0,0,0,0.05); text-decoration: none; 
            color: #2d3436; transition: 0.3s; border-top: 8px solid #6c5ce7;
            display: flex; flex-direction: column; justify-content: space-between;
            min-height: 140px;
        }
        .card:hover { transform: translateY(-10px); box-shadow: 0 15px 30px rgba(108, 92, 231, 0.2); }
        .category { color: #6c5ce7; font-weight: bold; font-size: 0.9rem; margin-bottom: 10px; display: block; }
        .card-title { font-size: 1.4rem; font-weight: 800; line-height: 1.3; }
        .go-btn { text-align: right; color: #6c5ce7; font-weight: bold; margin-top: 20px; font-size: 0.9rem; }
        .admin-footer { margin-top: 80px; text-align: center; color: #b2bec3; font-size: 0.8rem; }
    </style>
</head>
<body>
    <header>
        <img src="/최종 3.png" alt="학원 로고" class="logo" onerror="this.style.display='none';" /> 
        <h1>파이썬 수업 자료실</h1>
        <p>코딩으로 미래를 그리는 즐거운 교실</p>
    </header>

    <div class="grid">
        {lessons.length === 0 && <p style="grid-column: 1/-1;">아직 등록된 수업이 없습니다.</p>}

        {lessons.map((lesson) => {
            // 1. 파일 경로(lesson.file)에서 파일명 추출
            const fileName = getFileName(lesson.file);
            
            // 2. 제목 결정: 파일 안의 title 정보가 없으면 파일명을 제목으로 사용
            const displayTitle = (lesson.frontmatter && lesson.frontmatter.title) 
                                 ? lesson.frontmatter.title 
                                 : fileName.replace(/-/g, ' ');

            // 3. 링크 결정: /lessons/파일명 형식으로 강제 설정
            const targetUrl = `/lessons/${fileName}/`;

            return (
                <a href={targetUrl} class="card">
                    <div>
                        <span class="category">파이썬 수업</span>
                        <div class="card-title">{displayTitle}</div>
                    </div>
                    <div class="go-btn">수업 입장하기 →</div>
                </a>
            );
        })}
    </div>

    <div class="admin-footer">
        <a href="/admin/" style="color: inherit; text-decoration: none;">관리자 전용 로그인</a>
    </div>
</body>
</html>
