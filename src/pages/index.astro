---
// 에러가 절대 나지 않도록 가장 단순하게 구성한 코드입니다.
const lessons = await Astro.glob('./lessons/*.html');
---

<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>CODE:N ACADEMY - 파이썬 수업 자료실</title>
    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.8/dist/web/static/pretendard.css" />
    <style>
        body { font-family: 'Pretendard', sans-serif; background: #f5f6fa; margin: 0; padding: 40px; color: #2d3436; text-align: center; }
        header { margin-bottom: 50px; }
        .logo { width: 180px; height: auto; margin-bottom: 15px; } 
        h1 { font-size: 2.5rem; color: #6c5ce7; margin-top: 10px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; max-width: 1000px; margin: 0 auto; }
        .card { background: white; border-radius: 20px; padding: 30px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); text-decoration: none; color: #6c5ce7; transition: 0.3s; font-weight: bold; font-size: 1.2rem; display: flex; align-items: center; justify-content: center; min-height: 100px; border: 2px solid transparent; }
        .card:hover { transform: translateY(-5px); border-color: #6c5ce7; box-shadow: 0 15px 30px rgba(108, 92, 231, 0.1); }
        .admin-footer { margin-top: 80px; color: #b2bec3; font-size: 0.8rem; }
    </style>
</head>
<body>
    <header>
        <!-- 로고 이미지 -->
        <img src="/logo.png" alt="학원 로고" class="logo" onerror="this.style.display='none';" /> 
        <h1>파이썬 수업 자료실</h1>
        <p>코딩으로 미래를 그리는 즐거운 교실</p>
    </header>

    <div class="grid">
        {lessons.length === 0 && <p>아직 등록된 수업이 없습니다.</p>}

        {lessons.map((lesson) => (
            <a href={lesson.url || "#"} class="card">
                {lesson.frontmatter?.title || "파이썬 수업 자료"}
            </a>
        ))}
    </div>

    <div class="admin-footer">
        <a href="/admin/" style="color: inherit; text-decoration: none;">관리자 전용 로그인</a>
    </div>
</body>
</html>
